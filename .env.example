# Database Configuration Example
# Copy this file to .env and update with your actual values

# PostgreSQL Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=faddom
DB_USER=faddom
DB_PASSWORD=your_password_here

# Connection Pool Settings
DB_MIN_CONN=1
DB_MAX_CONN=10

# Flow Table Name
DB_FLOW_TABLE=network_flows
